@model CleanCity.MVC.Models.LoginViewModel
@{
    ViewData["Title"] = "تسجيل الدخول";
    Layout = null;
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/css/components/login.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="" />
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;600;700;800;900&display=swap" rel="stylesheet" />
</head>
<body>

    <div class="orb orb--1" aria-hidden="true"></div>
    <div class="orb orb--2" aria-hidden="true"></div>
    <div class="orb orb--3" aria-hidden="true"></div>

    <main class="page">
        <div class="card" role="main">

            <div class="card__header">
                <div class="logo-ring">
                    <img src="~/logo.png" alt="شعار التطبيق" />
                </div>
                <h1 class="card__title">مرحباً بعودتك</h1>
                <p class="card__subtitle">سجّل دخولك للمتابعة</p>
            </div>

            <div class="card__body">

                @* ✅ تم تصحيح: asp-controller + asp-action بدلاً من asp-page-handler *@
                <form method="post"
                      asp-controller="Login"
                      asp-action="Index"
                      class="form"
                      novalidate>

                    @Html.AntiForgeryToken()

                    <div asp-validation-summary="ModelOnly" class="validation-summary" role="alert"></div>

                    <!-- Username -->
                    <div class="field">
                        <label class="field__label" for="username">اسم المستخدم</label>
                        <div class="input-wrap">
                            <input id="username"
                                   asp-for="Input.Username"
                                   class="field__input"
                                   type="text"
                                   placeholder="أدخل اسم المستخدم"
                                   autocomplete="username"
                                   required
                                   autofocus />
                            <span class="input-wrap__icon" aria-hidden="true">
                                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                     stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                                    <circle cx="12" cy="7" r="4" />
                                </svg>
                            </span>
                        </div>
                        <span asp-validation-for="Input.Username" class="validation-summary"></span>
                    </div>

                    <!-- Password -->
                    <div class="field">
                        <label class="field__label" for="password">كلمة المرور</label>
                        <div class="input-wrap">
                            <input id="password"
                                   asp-for="Input.Password"
                                   class="field__input"
                                   type="password"
                                   placeholder="أدخل كلمة المرور"
                                   autocomplete="current-password"
                                   required />
                            <span class="input-wrap__icon" aria-hidden="true">
                                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                     stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                                    <path d="M7 11V7a5 5 0 0 1 10 0v4" />
                                </svg>
                            </span>
                        </div>
                        <span asp-validation-for="Input.Password" class="validation-summary"></span>
                    </div>

                    <button type="submit" class="btn-login">تسجيل الدخول</button>

                </form>
            </div>

        </div>
    </main>

</body>
</html>
