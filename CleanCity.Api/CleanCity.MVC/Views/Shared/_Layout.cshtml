    <!-- ── SignalR Client ──────────────────────────────────────────────────── -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.7/signalr.min.js"></script>
    <script>
        (function () {
            const connection = new signalR.HubConnectionBuilder()
                .withUrl("/hubs/dashboard")
                .withAutomaticReconnect()
                .build();

            connection.on("Refresh", function () {
                window.location.reload();
            });

            connection.start().catch(function (err) {
                console.error("SignalR connection error:", err);
            });

            // ✅ إغلاق الاتصال عند مغادرة الصفحة بالطريقة الحديثة
            window.addEventListener('pagehide', function () {
                connection.stop();
            });
        })();
    </script>

    <script>
        (function () {

            // ── Sidebar collapse ─────────────────────────────────────────────
            var KEY     = 'cc_sidebar_collapsed';
            var sidebar = document.getElementById('sidebar');
            var btn     = document.getElementById('btnCollapse');

            function load()    { try { return localStorage.getItem(KEY); } catch(e) { return null; } }
            function save(val) { try { localStorage.setItem(KEY, val);   } catch(e) {} }

            if (sidebar && btn) {
                if (load() === '1') sidebar.classList.add('sidebar--collapsed');
                btn.addEventListener('click', function () {
                    save(sidebar.classList.toggle('sidebar--collapsed') ? '1' : '0');
                });
            }

            var mb = document.getElementById('btnMobileMenu');
            if (mb) mb.addEventListener('click', function () { sidebar.classList.toggle('is-open'); });

            // ── Dropdown groups ──────────────────────────────────────────────
            document.querySelectorAll('.nav__group-toggle').forEach(function (toggleBtn) {
                toggleBtn.addEventListener('click', function () {
                    var isOpen = toggleBtn.classList.contains('is-open');
                    var items  = toggleBtn.nextElementSibling;

                    // أغلق كل الأقسام الأخرى
                    document.querySelectorAll('.nav__group-toggle').forEach(function (other) {
                        other.classList.remove('is-open');
                        other.nextElementSibling.classList.remove('is-open');
                    });

                    // افتح أو أغلق القسم الحالي
                    if (!isOpen) {
                        toggleBtn.classList.add('is-open');
                        items.classList.add('is-open');
                    }
                });
            });

            // ── تسجيل الخروج ────────────────────────────────────────────────
            document.addEventListener('DOMContentLoaded', function () {
                var userChip = document.getElementById('userChip');
                if (userChip) {
                    userChip.addEventListener('click', function () {
                        if (confirm('هل تريد تسجيل الخروج؟')) {
                            window.location.href = '/login/Index';
                        }
                    });
                }
            });

        })();
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

