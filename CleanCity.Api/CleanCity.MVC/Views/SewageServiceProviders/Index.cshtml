@model IEnumerable<CleanCity.Domain.Entities.SewageServiceProvider>


    <header class="topbar">
        <button class="icon-btn topbar__menu" id="btnMobileMenu" type="button" aria-label="فتح القائمة">
            <span class="icon" aria-hidden="true">≡</span>
        </button>

        <div class="topbar__title">
            <h1 class="page-title">عرض شفاطات المجاري</h1>
            <p class="page-subtitle">قائمة شفاطات المجاري</p>
        </div>

        <div class="topbar__actions">
            <a class="btn btn--primary" asp-controller="SewageServiceProviders" asp-action="Index" aria-label="تحديث الصفحة">تحديث</a>
        </div>
    </header>

    <section class="content" aria-live="polite">
        <section class="panel">
            <div class="panel__header">
                <h2 class="panel__title">شفاطات المجاري</h2>
                <div class="panel__meta">@((Model?.Count() ?? 0)) سجلات</div>
            </div>

            <div class="table-wrap">
                <table class="table">
                    <thead>
                        <tr>
                            <th>الكود</th>
                            <th>اسم السائق</th>
                            <th>رقم الهاتف</th>
                            <th>سعر الشفط</th>
                            <th>السعة (لتر)</th>
                            <th>إجراءات</th>
                        </tr>
                    </thead>

                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var p in Model)
                            {
                                <tr>
                                    <!-- كود شكلي من Id -->
                                    <td>SWG-@p.Id.ToString("D2")</td>

                                    <td>@p.OwnerName</td>

                                    <td>@p.PhoneNumber</td>

                                    <td>@p.Price</td>

                                    <td>@p.Size</td>

                             
                                    <td>
                                        <div class="row-actions">
                                            <a class="btn btn--sm"
                                               asp-controller="SewageServiceProviders"
                                               asp-action="Details"
                                               asp-route-id="@p.Id">تفاصيل</a>

                                            <a class="btn btn--sm btn--primary"
                                               asp-controller="SewageServiceProviders"
                                               asp-action="Edit"
                                               asp-route-id="@p.Id">تعديل</a>

                                            <form asp-controller="SewageServiceProviders"
                                                  asp-action="Delete"
                                                  asp-route-id="@p.Id"
                                                  method="post"
                                                  style="display:inline">
                                                @Html.AntiForgeryToken()
                                                <button class="btn btn--sm btn--danger" type="submit">حذف</button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="7" style="text-align:center; opacity:.8;">لا توجد شفاطات مسجلة.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="panel__footer">
                <a class="btn btn--primary"
                   asp-controller="SewageServiceProviders"
                   asp-action="Create">إضافة شفاط مجاري</a>
            </div>
        </section>
    </section>
