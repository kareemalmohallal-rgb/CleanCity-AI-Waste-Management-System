@model CleanCity.Domain.Entities.TruckType

    <header class="topbar">
        <button class="icon-btn topbar__menu" id="btnMobileMenu" type="button" aria-label="فتح القائمة">
            <span class="icon" aria-hidden="true">≡</span>
        </button>

        <div class="topbar__title">
            <h1 class="page-title">إضافة نوع شاحنة</h1>
        <p class="page-subtitle">تعريف نوع جديد</p>
        </div>

        <div class="topbar__actions">
            <div class="pill">
                <span class="pill__label">الوقت:</span>
                <span class="pill__value">—</span>
            </div>

            <a class="btn btn--primary" href="" aria-label="تحديث الصفحة">تحديث</a>
        </div>
    </header>

    <section class="content" aria-live="polite">
        <section class="panel">
            <div class="panel__header">
                <h2 class="panel__title">إضافة نوع شاحنة</h2>
                <div class="panel__meta">تعريف نوع (Type)</div>
            </div>

            <form style="padding:14px"
                  asp-controller="TruckTypes"
                  asp-action="Create"
                  method="post">
                @Html.AntiForgeryToken()

                <div class="filters" style="grid-template-columns:1fr 1fr; align-items:start">

                    <!-- الاسم -->
                    <label class="field">
                        <span class="field__label">الاسم</span>
                        <input class="field__control"
                               asp-for="Name"
                               type="text"
                               placeholder="مثال: ضاغطة / قلّاب / صهريج ..."
                               required />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </label>

                    <div class="filters__actions" style="align-self:end">
                        <!-- مسح: يرجع لنفس صفحة Create لتفريغ الحقول -->
                        <a class="btn"
                           asp-controller="TruckTypes"
                           asp-action="Create">
                            مسح
                        </a>

                        <!-- حفظ: Submit -->
                        <button class="btn btn--primary" type="submit">حفظ</button>
                    </div>

                </div>

                <div style="margin-top:10px">
                    @Html.ValidationSummary(true, "", new { @class = "text-danger" })
                </div>
            </form>
        </section>
    </section>
