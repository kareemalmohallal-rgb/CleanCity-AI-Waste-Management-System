@model CleanCity.Domain.Entities.TruckType

<header class="topbar">
    <button class="icon-btn topbar__menu" id="btnMobileMenu" type="button" aria-label="فتح القائمة">
        <span class="icon" aria-hidden="true">≡</span>
    </button>
    <div class="topbar__title">
        <h1 class="page-title">تعديل نوع شاحنة</h1>
        <p class="page-subtitle">TYP-@Model.Id.ToString("D2")</p>
    </div>
    <div class="topbar__actions">
        <a class="btn" asp-controller="TruckTypes" asp-action="Index">رجوع</a>
    </div>
</header>

<section class="content" aria-live="polite">
    <section class="panel">
        <div class="panel__header">
            <h2 class="panel__title">تعديل نوع شاحنة</h2>
            <div class="panel__meta">TYP-@Model.Id.ToString("D2")</div>
        </div>

        <form style="padding:14px"
              asp-controller="TruckTypes"
              asp-action="Edit"
              asp-route-id="@Model.Id"
              method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />

            <div class="filters" style="grid-template-columns:1fr 1fr; align-items:start">

                <label class="field">
                    <span class="field__label">الاسم</span>
                    <input class="field__control"
                           asp-for="Name"
                           type="text"
                           placeholder="مثال: ضاغطة / قلّاب / صهريج ..."
                           required />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </label>

                <div class="filters__actions" style="align-self:end">
                    <a class="btn" asp-controller="TruckTypes" asp-action="Index">إلغاء</a>
                    <button class="btn btn--primary" type="submit">حفظ التعديل</button>
                </div>

            </div>

            <div style="margin-top:10px">
                @Html.ValidationSummary(true, "", new { @class = "text-danger" })
            </div>
        </form>
    </section>
</section>