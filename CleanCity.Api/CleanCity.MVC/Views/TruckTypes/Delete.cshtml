@model CleanCity.Domain.Entities.TruckType

<header class="topbar">
    <button class="icon-btn topbar__menu" id="btnMobileMenu" type="button" aria-label="فتح القائمة">
        <span class="icon" aria-hidden="true">≡</span>
    </button>
    <div class="topbar__title">
        <h1 class="page-title">حذف نوع شاحنة</h1>
        <p class="page-subtitle">تأكيد الحذف</p>
    </div>
    <div class="topbar__actions">
        <a class="btn" asp-controller="TruckTypes" asp-action="Index">رجوع</a>
    </div>
</header>

<section class="content" aria-live="polite">
    <section class="panel">
        <div class="panel__header">
            <h2 class="panel__title">تأكيد حذف نوع الشاحنة</h2>
            <div class="panel__meta">TYP-@Model.Id.ToString("D2")</div>
        </div>

        @if (!ViewData.ModelState.IsValid)
        {
            <div style="margin:16px; padding:12px 16px; background:rgba(220,53,69,.12); border:1px solid rgba(220,53,69,.4); border-radius:8px; color:#dc3545;">
                @Html.ValidationSummary(false, "", new { @class = "text-danger", style = "margin:0; padding:0; list-style:none;" })
            </div>
        }

        <div style="padding:16px">
            <div class="kv">
                <div class="kv__k">الكود</div>
                <div class="kv__v">TYP-@Model.Id.ToString("D2")</div>

                <div class="kv__k">الاسم</div>
                <div class="kv__v">@Model.Name</div>
            </div>

            <div class="panel__footer" style="padding:14px 0 0; border-top:0; display:flex; gap:10px;">
                <form asp-controller="TruckTypes"
                      asp-action="Delete"
                      asp-route-id="@Model.Id"
                      method="post">
                    @Html.AntiForgeryToken()
                    <button class="btn btn--danger" type="submit">تأكيد الحذف</button>
                </form>
                <a class="btn" asp-controller="TruckTypes" asp-action="Index">إلغاء</a>
            </div>
        </div>
    </section>
</section>