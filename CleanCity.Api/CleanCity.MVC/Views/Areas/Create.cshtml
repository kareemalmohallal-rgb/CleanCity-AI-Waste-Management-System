
<style>
    /* خريطة داخل الـPanel */
    .map-wrap {
        border-radius: 14px;
        overflow: hidden;
        border: 1px solid rgba(255,255,255,.08);
        background: rgba(0,0,0,.12);
        margin-top: 10px;
    }

    #map {
        width: 100%;
        height: 650px;
    }

    /* بلوك معلومات الإحداثيات */
    .coords-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 10px;
        margin-top: 10px;
    }

    .coord-pill {
        padding: 10px 12px;
        border-radius: 12px;
        border: 1px solid rgba(255,255,255,.08);
        background: rgba(255,255,255,.04);
        font-size: 13px;
        line-height: 1.7;
    }

        .coord-pill b {
            font-weight: 800;
        }

        .coord-pill span {
            float: left;
            opacity: .95;
            font-weight: 700;
        }

    .map-search {
        position: absolute;
        top: 10px;
        right: 10px;
        z-index: 1000;
        display: flex;
        gap: 6px;
        background: rgba(20,30,40,.92);
        padding: 8px 10px;
        border-radius: 10px;
        border: 1px solid rgba(255,255,255,.1);
        backdrop-filter: blur(6px);
        width: 280px;
    }

        .map-search input {
            flex: 1;
            background: rgba(255,255,255,.08);
            border: 1px solid rgba(255,255,255,.12);
            border-radius: 7px;
            color: #e0e0e0;
            padding: 6px 10px;
            font-size: 13px;
            outline: none;
        }

            .map-search input::placeholder {
                opacity: .5;
            }

        .map-search button {
            background: #28a745;
            border: none;
            border-radius: 7px;
            color: #fff;
            padding: 6px 12px;
            font-size: 13px;
            cursor: pointer;
            white-space: nowrap;
        }

            .map-search button:hover {
                background: #218838;
            }
</style>

@model CleanCity.Domain.Entities.Area
<!-- Main -->
<main class="main">
    <header class="topbar">
        <button class="icon-btn topbar__menu" id="btnMobileMenu" type="button" aria-label="فتح القائمة">
            <span class="icon" aria-hidden="true">≡</span>
        </button>

        <div class="topbar__title">
            <h1 class="page-title">إضافة منطقة</h1>
            <p class="page-subtitle">رسم المنطقة على الخريطة (Leaflet)</p>
        </div>

        <div class="topbar__actions">
            <a class="btn btn--primary" href="" aria-label="تحديث الصفحة">تحديث</a>
        </div>
    </header>

    <section class="content" aria-live="polite">
        <section class="panel">
            <div class="panel__header">
                <h2 class="panel__title">إضافة منطقة</h2>
                <div class="panel__meta">ارسم مستطيلاً على الخريطة ثم احفظ</div>
            </div>

            <form asp-controller="Areas" asp-action="Create" method="post" id="areaForm">
                @Html.AntiForgeryToken()

                <!-- إحداثيات المستطيل (يتم تعبئتها من الخريطة) -->
                <input asp-for="MinLat" type="hidden" id="minLatH" />
                <input asp-for="MinLng" type="hidden" id="minLngH" />
                <input asp-for="MaxLat" type="hidden" id="maxLatH" />
                <input asp-for="MaxLng" type="hidden" id="maxLngH" />

                <div class="filters" style="grid-template-columns:1fr 1fr; align-items:start; padding:14px">

                    <label class="field">
                        <span class="field__label">اسم المنطقة</span>
                        <input class="field__control" asp-for="Name" type="text" placeholder="مثال: شعوب" required />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </label>

                    <div class="filters__actions" style="align-self:end">
                        <a asp-controller="Areas" asp-action="Index" class="btn">إلغاء</a>
                        <button type="submit" class="btn btn--primary">إضافة</button>
                    </div>

                </div>

                <!-- عرض الإحداثيات: صفين، قيمتان في كل سطر -->
                <div class="coords-grid" style="padding:0 14px">
                    <div class="coord-pill">الشمال (MaxLat): <span id="maxLat">-</span></div>
                    <div class="coord-pill">الشرق (MaxLng): <span id="maxLng">-</span></div>
                    <div class="coord-pill">الجنوب (MinLat): <span id="minLat">-</span></div>
                    <div class="coord-pill">الغرب (MinLng): <span id="minLng">-</span></div>
                </div>

                <!-- مكان الخريطة -->
                <div class="map-wrap" style="margin:10px 14px 14px; position:relative;">
                    <div class="map-search">
                        <input id="searchInput" type="text" placeholder="ابحث عن موقع..." />
                        <button type="button" id="btnSearch">بحث</button>
                    </div>
                    <div id="map" aria-label="خريطة رسم المنطقة"></div>
                </div>

            </form>
        </section>
    </section>
</main>

<!-- Leaflet Scripts -->
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/leaflet.draw/1.0.4/leaflet.draw.js"></script>

<script>
    // =========================
    // 1) حدود "محافظة صنعاء" (Bounding Box)
    // =========================
    const SANA_A_GOV_BOUNDS = L.latLngBounds(
      L.latLng(14.747906, 43.506874),
      L.latLng(16.045959, 45.108608)
    );

    const SANA_A_CITY_CENTER = [15.356695, 44.200218];

    // =========================
    // 2) إنشاء الخريطة + منع الخروج خارج الحدود
    // =========================
    const map = L.map('map', {
      center: SANA_A_CITY_CENTER,
      zoom: 12,
      minZoom: 9,
      maxZoom: 19,
      maxBounds: SANA_A_GOV_BOUNDS,
      maxBoundsViscosity: 1.0,
      worldCopyJump: true,
      zoomControl: true
    });

    const osm = L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
      maxZoom: 19,
      attribution: '&copy; OpenStreetMap contributors'
    });

    const esri = L.tileLayer(
      'https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}',
      { maxZoom: 19, attribution: 'Tiles &copy; Esri' }
    );

    esri.addTo(map);

    L.control.layers(
      { "صور عالية الدقة (Esri)": esri, "خريطة عادية (OSM)": osm },
      null,
      { position: 'topleft' }
    ).addTo(map);

    L.control.scale({ imperial: false }).addTo(map);

    // =========================
    // 3) أدوات الرسم: مستطيل فقط + تعديل/حذف
    // =========================
    const drawnItems = new L.FeatureGroup();
    map.addLayer(drawnItems);

    const drawControl = new L.Control.Draw({
      position: 'topleft',
      draw: {
        polyline: false,
        circle: false,
        marker: false,
        circlemarker: false,
        polygon: false,
        rectangle: { shapeOptions: { color: '#28a745', weight: 2 } }
      },
      edit: { featureGroup: drawnItems, remove: true }
    });
    map.addControl(drawControl);

    // =========================
    // 4) Helpers
    // =========================
    const el = (id) => document.getElementById(id);
    let lastLayer = null;

    function boundsToObj(bounds) {
      return {
        minLat: +bounds.getSouthWest().lat.toFixed(6),
        minLng: +bounds.getSouthWest().lng.toFixed(6),
        maxLat: +bounds.getNorthEast().lat.toFixed(6),
        maxLng: +bounds.getNorthEast().lng.toFixed(6),
      };
    }

    function setCoordsUI(bounds) {
      const b = boundsToObj(bounds);

      el('maxLat').innerText = b.maxLat.toFixed(6);
      el('maxLng').innerText = b.maxLng.toFixed(6);
      el('minLat').innerText = b.minLat.toFixed(6);
      el('minLng').innerText = b.minLng.toFixed(6);

      el('minLatH').value = b.minLat;
      el('minLngH').value = b.minLng;
      el('maxLatH').value = b.maxLat;
      el('maxLngH').value = b.maxLng;
    }

    function clearCoordsUI() {
      el('maxLat').innerText = '-';
      el('maxLng').innerText = '-';
      el('minLat').innerText = '-';
      el('minLng').innerText = '-';

      el('minLatH').value = '';
      el('minLngH').value = '';
      el('maxLatH').value = '';
      el('maxLngH').value = '';
    }

    function attachLayerEvents(layer) {
      layer.on('click', () => {
        lastLayer = layer;
        setCoordsUI(layer.getBounds());
        map.fitBounds(layer.getBounds(), { padding: [20,20] });
      });
    }

    function refreshButtons() {
      const hasAny = drawnItems.getLayers().length > 0;
      el('btnSave') && (el('btnSave').disabled = (lastLayer === null));
    }

    // =========================
    // 5) Events: Created / Edited / Deleted
    // =========================
    map.on(L.Draw.Event.CREATED, function (e) {
      const layer = e.layer;

      if (!SANA_A_GOV_BOUNDS.contains(layer.getBounds())) {
        alert('المربع يجب أن يكون داخل حدود محافظة صنعاء فقط.');
        return;
      }

      drawnItems.addLayer(layer);
      lastLayer = layer;

      attachLayerEvents(layer);
      setCoordsUI(layer.getBounds());
      refreshButtons();
    });

    map.on(L.Draw.Event.EDITED, function (e) {
      e.layers.eachLayer(function (layer) {
        if (!SANA_A_GOV_BOUNDS.contains(layer.getBounds())) {
          alert('لا يمكن تعديل المربع ليخرج خارج حدود محافظة صنعاء.');
          map.fitBounds(SANA_A_GOV_BOUNDS);
          return;
        }
        lastLayer = layer;
        setCoordsUI(layer.getBounds());
      });
      refreshButtons();
    });

    map.on(L.Draw.Event.DELETED, function () {
      if (lastLayer && !drawnItems.hasLayer(lastLayer)) {
        lastLayer = null;
        clearCoordsUI();
      }
      if (drawnItems.getLayers().length === 0) {
        lastLayer = null;
        clearCoordsUI();
      }
      refreshButtons();
    });

    // =========================
    // 6) البحث عن موقع (Nominatim)
    // =========================
    let searchMarker = null;

    async function searchLocation() {
      const query = el('searchInput').value.trim();
      if (!query) return;

      try {
        const res = await fetch(
          `https://nominatim.openstreetmap.org/search?q=${encodeURIComponent(query)}&format=json&limit=1&countrycodes=ye`,
          { headers: { 'Accept-Language': 'ar' } }
        );
        const data = await res.json();

        if (!data.length) {
          alert('لم يتم العثور على الموقع. حاول بكلمة أخرى.');
          return;
        }

        const { lat, lon, display_name } = data[0];
        const latlng = L.latLng(parseFloat(lat), parseFloat(lon));

        if (searchMarker) map.removeLayer(searchMarker);

        searchMarker = L.marker(latlng)
          .addTo(map)
          .bindPopup(display_name)
          .openPopup();

        map.setView(latlng, 15);

      } catch {
        alert('حدث خطأ أثناء البحث. تحقق من الاتصال.');
      }
    }

    el('btnSearch').addEventListener('click', searchLocation);
    el('searchInput').addEventListener('keydown', (e) => {
      if (e.key === 'Enter') { e.preventDefault(); searchLocation(); }
    });

    refreshButtons();
</script>
