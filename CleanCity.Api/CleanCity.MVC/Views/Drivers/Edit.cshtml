@model CleanCity.Domain.Entities.Driver
@{
    ViewData["Title"] = "تعديل سائق";
}

<header class="topbar">
    <button class="icon-btn topbar__menu" id="btnMobileMenu" type="button" aria-label="فتح القائمة">
        <span class="icon" aria-hidden="true">≡</span>
    </button>

    <div class="topbar__title">
        <h1 class="page-title">تعديل سائق</h1>
        <p class="page-subtitle">DRV-@Model.Id.ToString("D2")</p>
    </div>

    <div class="topbar__actions">
        <a class="btn" asp-controller="Drivers" asp-action="Index">رجوع</a>
    </div>
</header>

<section class="content" aria-live="polite">
    <section class="panel">
        <div class="panel__header">
            <h2 class="panel__title">بيانات السائق</h2>
            <div class="panel__meta">تحديث بيانات السائق</div>
        </div>

        <form style="padding:14px"
              asp-controller="Drivers"
              asp-action="Edit"
              asp-route-id="@Model.Id"
              method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />

            <div class="filters" style="grid-template-columns:1fr 1fr; align-items:start">

                <!-- FullName -->
                <label class="field">
                    <span class="field__label">اسم السائق</span>
                    <input class="field__control" asp-for="FullName" type="text" placeholder="مثال: محمد أحمد" required />
                    <span asp-validation-for="FullName" class="text-danger"></span>
                </label>

                <!-- PhoneNumber -->
                <label class="field">
                    <span class="field__label">رقم الهاتف</span>
                    <input class="field__control" asp-for="PhoneNumber" type="tel" placeholder="مثال: 7xxxxxxxx" required />
                    <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                </label>

                <!-- LicenseNumber -->
                <label class="field">
                    <span class="field__label">رقم الرخصة</span>
                    <input class="field__control" asp-for="LicenseNumber" type="text" placeholder="مثال: YEM-123456" />
                    <span asp-validation-for="LicenseNumber" class="text-danger"></span>
                </label>

                <!-- IsActive -->
                <label class="field">
                    <span class="field__label">الحالة</span>
                    <select class="field__control" asp-for="IsActive">
                        <option value="true">نشط</option>
                        <option value="false">غير نشط</option>
                    </select>
                    <span asp-validation-for="IsActive" class="text-danger"></span>
                </label>

                <!-- AreaId -->
                <label class="field">
                    <span class="field__label">المنطقة</span>
                    <select class="field__control" asp-for="AreaId" asp-items="ViewBag.Areas">
                        <option value="">اختر المنطقة</option>
                    </select>
                    <span asp-validation-for="AreaId" class="text-danger"></span>
                </label>

                <!-- TruckId -->
                <label class="field">
                    <span class="field__label">الشاحنة</span>
                    <select class="field__control" asp-for="TruckId" asp-items="ViewBag.Trucks">
                        <option value="">اختر الشاحنة</option>
                    </select>
                    <span asp-validation-for="TruckId" class="text-danger"></span>
                </label>

                <div class="filters__actions" style="align-self:end">
                    <a class="btn" asp-controller="Drivers" asp-action="Index">إلغاء</a>
                    <button class="btn btn--primary" type="submit">حفظ التعديل</button>
                </div>
            </div>

            <div style="margin-top:10px">
                @Html.ValidationSummary(true, "", new { @class = "text-danger" })
            </div>
        </form>
    </section>
</section>