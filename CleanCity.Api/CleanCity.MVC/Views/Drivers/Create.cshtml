@model CleanCity.Domain.Entities.Driver
    <header class="topbar">
        <button class="icon-btn topbar__menu" id="btnMobileMenu" type="button" aria-label="فتح القائمة">
            <span class="icon" aria-hidden="true">≡</span>
        </button>

        <div class="topbar__title">
            <h1 class="page-title">إضافة سائق</h1>
            <p class="page-subtitle">نموذج ثابت (بدون حفظ فعلي)</p>
        </div>

        <div class="topbar__actions">
            <div class="pill">
                <span class="pill__label">الوقت:</span>
                <span class="pill__value">—</span>
            </div>

            <a class="btn btn--primary" href="" aria-label="تحديث الصفحة">تحديث</a>
        </div>
    </header>

    <section class="content" aria-live="polite">
        <section class="panel">
            <div class="panel__header">
                <h2 class="panel__title">إضافة سائق</h2>
                <div class="panel__meta">نموذج إدخال</div>
            </div>

            <form style="padding:14px"
                  asp-controller="Drivers"
                  asp-action="Create"
                  method="post">
                @Html.AntiForgeryToken()

                <div class="filters" style="grid-template-columns:1fr 1fr; align-items:start">

                    <!-- اسم السائق -->
                    <label class="field">
                        <span class="field__label">اسم السائق</span>
                        <input class="field__control"
                               asp-for="FullName"
                               type="text"
                               placeholder="مثال: محمد أحمد"
                               required />
                        <span asp-validation-for="FullName" class="text-danger"></span>
                    </label>

                    <!-- رقم الهاتف -->
                    <label class="field">
                        <span class="field__label">رقم الهاتف</span>
                        <input class="field__control"
                               asp-for="PhoneNumber"
                               type="tel"
                               placeholder="مثال: 7xxxxxxxx"
                               required />
                        <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                    </label>

                    <!-- رقم الرخصة -->
                    <label class="field">
                        <span class="field__label">رقم الرخصة</span>
                        <input class="field__control"
                               asp-for="LicenseNumber"
                               type="text"
                               placeholder="مثال: YEM-123456" />
                        <span asp-validation-for="LicenseNumber" class="text-danger"></span>
                    </label>

                    <!-- حالة السائق (IsActive bool) -->
                    <label class="field">
                        <span class="field__label">حالة السائق</span>
                        <select class="field__control" asp-for="IsActive">
                            <option value="true">نشط</option>
                            <option value="false">غير نشط</option>
                        </select>
                        <span asp-validation-for="IsActive" class="text-danger"></span>
                    </label>

                    <!-- المنطقة -->
                    <label class="field">
                        <span class="field__label">المنطقة</span>
                        <select class="field__control"
                                asp-for="AreaId"
                                asp-items="ViewBag.Areas">
                            <option value="">اختر المنطقة</option>
                        </select>
                        <span asp-validation-for="AreaId" class="text-danger"></span>
                    </label>

                    <!-- الشاحنة -->
                    <label class="field">
                        <span class="field__label">الشاحنة</span>
                        <select class="field__control"
                                asp-for="TruckId"
                                asp-items="ViewBag.Trucks">
                            <option value="">اختر الشاحنة</option>
                        </select>
                        <span asp-validation-for="TruckId" class="text-danger"></span>
                    </label>

                    <!-- أزرار الإجراءات -->
                    <div class="filters__actions" style="align-self:end">
                        <!-- مسح: إعادة فتح Create لتفريغ الحقول -->
                        <a class="btn" asp-controller="Drivers" asp-action="Create">مسح</a>

                        <!-- حفظ: Submit -->
                        <button class="btn btn--primary" type="submit">حفظ</button>
                    </div>

                </div>

                <div style="margin-top:10px">
                    @Html.ValidationSummary(true, "", new { @class = "text-danger" })
                </div>
            </form>

        </section>
    </section>
