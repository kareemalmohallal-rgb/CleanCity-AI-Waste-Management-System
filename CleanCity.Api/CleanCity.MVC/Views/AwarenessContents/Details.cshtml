@model CleanCity.Domain.Entities.AwarenessContent

<header class="topbar">
    <button class="icon-btn topbar__menu" id="btnMobileMenu" type="button" aria-label="فتح القائمة">
        <span class="icon" aria-hidden="true">≡</span>
    </button>
    <div class="topbar__title">
        <h1 class="page-title">تفاصيل المقال</h1>
        <p class="page-subtitle">ART-@Model.Id.ToString("D2")</p>
    </div>
    <div class="topbar__actions">
        <a class="btn" asp-controller="AwarenessContents" asp-action="Index">رجوع</a>
    </div>
</header>

<section class="content" aria-live="polite">
    <section class="panel">
        <div class="panel__header">
            <h2 class="panel__title">@Model.Title</h2>
            <div class="panel__meta">@Model.CreatedAt.ToString("yyyy-MM-dd HH:mm")</div>
        </div>

        <div style="padding:16px">

            <!-- ───── صورة المقال ───── -->
            @if (!string.IsNullOrEmpty(Model.ImageUrl))
            {
                <div style="text-align:center; margin-bottom:20px;">
                    <img src="@Model.ImageUrl"
                         alt="صورة المقال"
                         style="max-width:100%;
                                    max-height:400px;
                                    border-radius:12px;
                                    border:2px solid rgba(0,0,0,.08);
                                    box-shadow:0 4px 16px rgba(0,0,0,.1);" />
                </div>
            }

            <div class="kv">
                <div class="kv__k">الكود</div>
                <div class="kv__v">ART-@Model.Id.ToString("D2")</div>

                <div class="kv__k">العنوان</div>
                <div class="kv__v">@Model.Title</div>

                <div class="kv__k">تاريخ النشر</div>
                <div class="kv__v">@Model.CreatedAt.ToString("yyyy-MM-dd HH:mm")</div>

                <div class="kv__k">الصورة</div>
                <div class="kv__v">
                    @if (!string.IsNullOrEmpty(Model.ImageUrl))
                    {
                        <span style="color:#198754;">✔ مرفقة</span>
                    }
                    else
                    {
                        <span style="opacity:.6;">— لا توجد صورة</span>
                    }
                </div>

                <div class="kv__k">المحتوى</div>
                <div class="kv__v" style="white-space:pre-wrap; line-height:1.8">@Model.Content</div>
            </div>

            <div class="panel__footer" style="padding:14px 0 0; border-top:0">
                <a class="btn" asp-controller="AwarenessContents" asp-action="Index">رجوع</a>
                <a class="btn btn--primary"
                   asp-controller="AwarenessContents"
                   asp-action="Edit"
                   asp-route-id="@Model.Id">تعديل</a>
            </div>
        </div>
    </section>
</section>